#Область ОбработчикиСобытийЭлементовШапкиФормы
&НаКлиенте
Процедура ДЗ_СогласованнаяСкидкаПриИзменении(Элемент)
	//Начало Ветхова 19.06.2026
	Если Объект.Товары.Количество() = 0 И Объект.Услуги.Количество() = 0  Тогда
		Возврат;
	Иначе
		Оповещение = Новый ОписаниеОповещения("ПослеЗакрытияВопроса", ЭтотОбъект);
		ПоказатьВопрос(Оповещение, "Изменен  процент скидки. Пересчитать сумму?", РежимДиалогаВопрос.ДаНетОтмена, 0);
	КонецЕсли;
	//Конец Ветхова 19.06.2026
КонецПроцедуры
#КонецОбласти

